<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F6F8">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add New Place / Building"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:gravity="center"
        android:paddingVertical="16dp"/>

    <!-- Name Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Place / Building Name"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. My New Dormitory"
        android:inputType="textCapWords"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- Address Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Full Address"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 123 Street Name, Brgy. City"
        android:inputType="textMultiLine"
        android:minLines="2"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- Price Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price / Rate"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. ₱3,000/month or ₱600/night"
        android:inputType="text"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- Type Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. Bedspace, Transient, Apartment"
        android:inputType="text"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- Rating Input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rating (e.g. 4.5)"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 4.7"
        android:inputType="numberDecimal"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="20dp"/>

    <!-- Save Button -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Save Place"
        android:background="#2196F3"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:elevation="2dp"/>

</LinearLayout>