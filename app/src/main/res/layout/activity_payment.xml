<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBE7A1">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:backgroundTint="#FFFFFF"
        android:layout_gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="25dp"
            android:layout_gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#4F494B"
                android:layout_gravity="center"
                android:layout_marginTop="10dp">
            </TextView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose your payment option"
                android:textSize="14sp"
                android:textColor="#999999"
                android:layout_gravity="center"
                android:layout_marginBottom="25dp">
            </TextView>

            <Spinner
                android:id="@+id/spPayment"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:backgroundTint="#FFE18A"
                android:padding="12dp">
            </Spinner>

            <EditText
                android:id="@+id/etGcashRef"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:backgroundTint="#FFE18A"
                android:hint="GCash Reference Number"
                android:inputType="number"
                android:padding="15dp"
                android:visibility="gone">
            </EditText>

            <EditText
                android:id="@+id/etCardRef"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:backgroundTint="#FFE18A"
                android:hint="Card Reference / Last 4 Digits"
                android:inputType="number"
                android:padding="15dp"
                android:visibility="gone">
            </EditText>

            <LinearLayout
                android:id="@+id/gcashInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFF8DC"
                android:padding="15dp"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GCash Number"
                    android:textStyle="bold"
                    android:textColor="#4F494B">
                </TextView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09123456789"
                    android:textSize="18sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="10dp">
                </TextView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Name"
                    android:textStyle="bold"
                    android:textColor="#4F494B">
                </TextView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SD Dormitory"
                    android:textSize="18sp"
                    android:textColor="#000000">
                </TextView>

            </LinearLayout>

            <Button
                android:id="@+id/btnPay"
                android:layout_width="250dp"
                android:layout_height="55dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="#FFE18A"
                android:text="Proceed Payment"
                android:textAllCaps="false"
                android:textColor="#4F494B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="center">
            </Button>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</ScrollView>